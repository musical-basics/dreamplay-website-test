  document.addEventListener('DOMContentLoaded', function() {
    // 🌐 Your website link
    const websiteLink = "https://www.dreamplaypianos.com";
    // 🧾 Shared message for Facebook & Twitter (X)
    const shareMessage = `I just became a Founder for the new DreamPlay One keyboard! It's a premium piano being created by Lionel Yu that features ergonomic narrow keys and a smart learning system. If you've ever felt the piano wasn't built for you, you have to see this. You can join the Founder's Circle for $1 here: ${websiteLink}`;
    // ✉️ Custom Email message
    const emailSubject = "Check out the DreamPlay One Keyboard!";
    const emailBody = `Hey, I just became a Founder for a new keyboard project called the DreamPlay One. It's being created by pianist Lionel Yu and features ergonomic narrow keys (finally!) and smart, light-up learning features.
It's a really cool concept, and I just joined the "Founder's Circle" for $1. It gets you an instant sheet music download and guarantees the best discount when it launches.
Thought you'd want to see it too:
${websiteLink}
Talk soon,`;
    // 🟦 FACEBOOK SHARE
    const fbBtn = document.querySelector('.share-fb');
    if (fbBtn) {
      fbBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const shareUrl = encodeURIComponent(websiteLink);
        const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
        window.open(fbUrl, 'facebook-share', 'width=600,height=400');
      });
    }
    // 🖤 TWITTER / X SHARE
    const twitterBtn = document.querySelector('.share-x');
    if (twitterBtn) {
      twitterBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const tweetText = encodeURIComponent(shareMessage);
        const twitterUrl = `https://twitter.com/intent/tweet?text=${tweetText}`;
        window.open(twitterUrl, 'twitter-share', 'width=600,height=400');
      });
    }
    // ✉️ EMAIL SHARE
    const emailBtn = document.querySelector('.share-email');
    if (emailBtn) {
      emailBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const subject = encodeURIComponent(emailSubject);
        const body = encodeURIComponent(emailBody);
        const mailto = `mailto:?subject=${subject}&body=${body}`;
        window.location.href = mailto;
      });
    }
  });
</script>
