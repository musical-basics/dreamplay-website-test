      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        const xPercent = ((e.clientX - rect.left) / rect.width) * 100;
        const yPercent = ((e.clientY - rect.top) / rect.height) * 100;
        const xOffset = (e.clientX - rect.left - rect.width / 2) / 50;
        const yOffset = (e.clientY - rect.top - rect.height / 2) / 50;
        if (glow) {
          glow.style.background = `radial-gradient(circle at ${xPercent}% ${yPercent}%, #4a9eff 0%, transparent 50%)`;
        }
        if (image) {
          image.style.transform = `translate(${xOffset * 2}px, calc(-50% + ${yOffset * 2}px))`;
        }
      });
