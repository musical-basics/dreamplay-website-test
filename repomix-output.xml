    if(state.size || state.color) {
        preview.classList.remove('hidden');
        preview.classList.add('flex');
        let html = '';
        if(state.size) html += `<span class="text-[#4a9eff]">${state.size}</span>`;
        if(state.size && state.color) html += `<span>•</span>`;
        if(state.color) html += `<span class="text-[#4a9eff]">${state.color}</span>`;
        preview.innerHTML = html;
    } else {
        preview.classList.add('hidden');
    }
}
// --- Renderers & Logic ---
// 1. Hand Size
function renderHandSizes() {
    const grid = document.getElementById('hand-size-grid');
    grid.innerHTML = HAND_SIZES.map(s => {
        const isSelected = state.handSpan === s.id;
        const borderClass = isSelected ? "border-[#4a9eff] bg-[#4a9eff]/10 ring-2 ring-[#4a9eff]/50" : "border-white/10 bg-white/5 hover:border-[#4a9eff]/50 hover:bg-[#4a9eff]/5";
        return `
        <button onclick="handleHandSelect('${s.id}')" class="group relative flex flex-col overflow-hidden rounded-xl border p-5 text-left transition-all duration-300 md:rounded-2xl md:p-6 ${borderClass}">
            ${isSelected ? `<div class="absolute right-3 top-3 flex h-6 w-6 items-center justify-center rounded-full bg-[#4a9eff] text-white">✓</div>` : ''}
            <div class="flex flex-1 flex-col items-center">
                <span class="text-4xl mb-3 grayscale group-hover:grayscale-0 transition-all opacity-70 group-hover:opacity-100">${s.emoji}</span>
                <h3 class="text-xl font-bold text-white mb-1">${s.label}</h3>
                <p class="text-center text-sm text-[#4a9eff]/80 mb-4 h-12">${s.desc}</p>
                <div class="text-sm font-light text-white/50 mb-4">${s.range}</div>
            </div>
            <div class="mt-auto w-full rounded-lg bg-white/5 p-3">
                 <div class="flex justify-between items-center mb-1">
                    <span class="text-white/70 font-semibold">${s.pianoSize}</span>
                    <span class="text-xs bg-white/10 px-2 rounded text-white/50">${s.zone}</span>
                 </div>
                 <p class="text-xs text-white/50">${s.keys} Keys</p>
            </div>
        </button>`;
    }).join('');
}
function handleHandSelect(id) {
    state.handSpan = id;
    const map = { small: 'DS5.5', medium: 'DS6.0', large: 'DS6.5' };
    state.size = map[id];
    document.getElementById('measure-recommendation').innerText = `We recommend the ${state.size} for your hand size.`;
    renderHandSizes();
    renderSizeCards();
    setTimeout(() => scrollToSection(2), 300);
}
// 2. Size Selection
function renderSizeCards() {
    const grid = document.getElementById('size-card-grid');
    document.getElementById('text-recommended-model').innerText = state.size || 'DS6.0';
    grid.innerHTML = Object.entries(KEYBOARDS).map(([key, data]) => {
        const isSelected = state.size === key;
        const borderClass = isSelected ? "border-[#4a9eff] shadow-2xl shadow-[#4a9eff]/20" : "border-white/10 hover:border-white/20";
        return `
        <button onclick="handleSizeSelect('${key}')" class="group relative overflow-hidden rounded-xl border text-left transition-all duration-300 ${borderClass}">
            ${isSelected ? `<div class="absolute right-2 top-2 z-10 rounded-full bg-gradient-to-r from-[#4a9eff] to-[#7dd3fc] px-2 py-0.5 text-[10px] font-bold uppercase text-white shadow-lg">Recommended</div>` : ''}
            <div class="absolute left-2 top-2 z-10 text-[10px] text-white/50 bg-white/10 px-2 rounded">${data.zone}</div>
            <div class="relative overflow-hidden bg-white/5 p-6 flex justify-center">
                 <img src="https://cdn.prod.website-files.com/6723a7dd85bce00279c0bc64/672a8e88dad4c3bb42a68cce_dreamplay-one-keyboard-front.webp" class="h-24 object-contain group-hover:scale-105 transition-transform" />
            </div>
            <div class="p-4">
                <h3 class="text-lg font-bold text-white">${data.name}</h3>
                <p class="text-xs text-white/60 mb-2">${data.tagline}</p>
                <div class="grid grid-cols-2 gap-2 mt-3">
                    <div class="bg-white/5 p-2 rounded">
                        <div class="text-[#4a9eff] font-bold">88</div>
                        <div class="text-[10px] text-white/50">Keys</div>
                    </div>
                     <div class="bg-white/5 p-2 rounded">
                        <div class="text-white font-bold text-xs">${data.keys}</div>
                        <div class="text-[10px] text-white/50">Width</div>
                    </div>
                </div>
                <div class="mt-3 text-center py-2 rounded text-sm font-semibold ${isSelected ? 'bg-[#4a9eff] text-white' : 'bg-white/10 text-white/60'}">
                    ${isSelected ? 'Selected' : 'Select'}
                </div>
            </div>
        </button>`;
    }).join('');
}
function handleSizeSelect(sizeKey) {
    state.size = sizeKey;
    renderSizeCards();
    updateOrderSummary();
    setTimeout(() => scrollToSection(3), 300);
}
// 3. Color Selection
function renderColorCards() {
    const colors = [
        { id: 'Black', name: 'Midnight Black', hex: '#1a1a1a', grad: 'linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%)' },
        { id: 'White', name: 'Pearl White', hex: '#f5f5f5', grad: 'linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%)' }
    ];
    const grid = document.getElementById('color-grid');
    grid.innerHTML = colors.map(c => {
        const isSelected = state.color === c.id;
        const borderClass = isSelected ? "border-[#4a9eff] shadow-2xl shadow-[#4a9eff]/20" : "border-white/10 hover:border-white/20";
        return `
        <button onclick="handleColorSelect('${c.id}')" class="group relative overflow-hidden rounded-xl border text-left transition-all duration-300 ${borderClass}">
            <div class="h-40 relative" style="background: ${c.grad}">
                <img src="https://cdn.prod.website-files.com/6723a7dd85bce00279c0bc64/672a8e88dad4c3bb42a68cce_dreamplay-one-keyboard-front.webp" 
                     class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] max-w-none group-hover:scale-110 transition-transform ${c.id === 'Black' ? 'brightness-50' : ''}" />
                ${isSelected ? `<div class="absolute right-3 top-3 bg-[#4a9eff] rounded-full w-8 h-8 flex items-center justify-center text-white font-bold">✓</div>` : ''}
            </div>
            <div class="p-5">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-5 h-5 rounded-full border border-white/20" style="background:${c.hex}"></div>
                    <h3 class="text-xl font-bold text-white">${c.name}</h3>
                </div>
                <div class="mt-3 text-center py-2 rounded text-sm font-semibold ${isSelected ? 'bg-[#4a9eff] text-white' : 'bg-white/10 text-white/60'}">
                    ${isSelected ? 'Selected' : 'Choose Finish'}
                </div>
            </div>
        </button>`;
    }).join('');
}
function handleColorSelect(colorId) {
    state.color = colorId;
    renderColorCards();
    updateOrderSummary();
    setTimeout(() => scrollToSection(4), 300);
}
// 4. Pricing / Checkout
function renderPricingTiers() {
    const grid = document.getElementById('pricing-grid');
    grid.innerHTML = PRICING_TIERS.map(t => {
        const isSelected = state.tier === t.id;
        const bgClass = isSelected ? "border-white bg-white/20 backdrop-blur-sm" : "border-white/20 bg-white/10 backdrop-blur-sm hover:border-white/40";
        return `
        <button onclick="handleTierSelect('${t.id}')" class="relative flex flex-col items-center rounded-2xl border p-6 text-center transition-all duration-300 ${bgClass}">
            ${t.recommended ? `<div class="absolute right-2 top-2 rounded-full bg-white px-3 py-1 text-xs font-bold text-[#4a9eff]">Best Value</div>` : ''}
            <div class="text-4xl font-bold text-white mt-4">${t.price}</div>
            <div class="text-lg font-medium text-white/90 mt-1">${t.name}</div>
            <div class="text-sm text-white/60 mt-2">${t.desc}</div>
            ${isSelected ? `<div class="mt-4 rounded-full bg-white px-4 py-1.5 text-xs font-semibold text-[#4a9eff]">Selected</div>` : ''}
        </button>`;
    }).join('');
}
function handleTierSelect(tierId) {
    state.tier = tierId;
    renderPricingTiers();
    updateSubmitButton();
    updateOrderSummary();
    setTimeout(() => scrollToSection(5), 300);
}
// 5. Contact & Summary
function updateSubmitButton() {
    const btn = document.getElementById('btn-submit');
    const note = document.getElementById('bundle-info');
    const tier = PRICING_TIERS.find(t => t.id === state.tier);
    btn.innerText = tier.id === 'waitlist' ? 'Join Waitlist' : `Pay ${tier.price} & Complete`;
    if(tier.id === 'full') note.innerText = "+ stand, bench and pedal included";
    else if(tier.id === 'deposit') note.innerText = "+ stand and pedal included";
    else note.innerText = "";
}
function updateOrderSummary() {
    const container = document.getElementById('order-summary');
    const tier = PRICING_TIERS.find(t => t.id === state.tier);
    const shipDate = state.size === 'DS6.5' ? 'April 2026' : 'July 2026';
    container.innerHTML = `
        <h3 class="mb-5 text-xl font-semibold text-white">Your Selection</h3>
        <div class="mb-5 bg-white/5 rounded-xl p-4 flex justify-center">
             <img src="https://cdn.prod.website-files.com/6723a7dd85bce00279c0bc64/672a8e88dad4c3bb42a68cce_dreamplay-one-keyboard-front.webp" class="h-20 object-contain" />
        </div>
        <div class="space-y-3 border-b border-white/10 pb-5 text-sm">
            <div class="flex justify-between"><span class="text-white/60">Model</span> <span class="text-white">DreamPlay One ${state.size || '-'}</span></div>
            <div class="flex justify-between"><span class="text-white/60">Finish</span> <span class="text-white">${state.color || '-'}</span></div>
            <div class="flex justify-between"><span class="text-white/60">Option</span> <span class="text-[#4a9eff]">${tier.name}</span></div>
            <div class="flex justify-between"><span class="text-white/60">Est. Shipping</span> <span class="text-white">${state.size ? shipDate : '-'}</span></div>
        </div>
        <div class="mt-5 flex justify-between items-center">
            <span class="text-white/60">Due Today</span>
            <span class="text-3xl font-bold text-[#4a9eff]">${tier.price}</span>
        </div>
    `;
}
// --- Form Submission with Toast ---
document.getElementById('order-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-submit');
    const originalText = btn.innerText;
    btn.innerHTML = `<svg class="animate-spin h-5 w-5 mr-2 inline" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Processing...`;
    setTimeout(() => {
        // Success Toast
        ToastSystem.show({
            title: "Reservation Received!",
            description: "We have sent a confirmation to your email address.",
            variant: "default"
        });
        btn.innerText = "Completed";
        // Example: If it failed, you would use:
        /*
        ToastSystem.show({
            title: "Error",
            description: "Something went wrong. Please try again.",
            variant: "destructive"
        });
        */
        // Reset button after a moment
        setTimeout(() => {
            updateSubmitButton();
        }, 3000);
    }, 2000);
});
// --- Extras: Countdown & Sizing Tool ---
function initCountdown() {
    let d = 0, h = 11, m = 4, s = 42;
    setInterval(() => {
        s--;
        if(s<0) { s=59; m--; }
        if(m<0) { m=59; h--; }
        const pad = (n) => n.toString().padStart(2,'0');
        const html = [
            {v:pad(d), l:'DAYS'}, {v:pad(h), l:'HOURS'}, {v:pad(m), l:'MIN'}, {v:pad(s), l:'SEC'}
        ].map(i => `
            <div class="text-center">
                <div class="text-3xl font-bold text-white md:text-5xl">${i.v}</div>
                <div class="text-[10px] text-white/60">${i.l}</div>
            </div>
        `).join('<span class="text-2xl text-white/40">:</span>');
        document.getElementById('countdown-container').innerHTML = html;
    }, 1000);
}
// Sizing Tool Modal Logic
function toggleModal(show) {
    const modal = document.getElementById('sizing-modal');
    if(show) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    } else {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }
}
function initSizingTool() {
    const slider = document.getElementById('dp-handspan-slider');
    const glow = document.getElementById('dp-glow-layer');
    const valDisplay = document.getElementById('dp-handspan-value');
    // Gradients for logic
    const cA = 'rgba(239, 68, 68, 1)'; // Red
    const cB = 'rgba(249, 115, 22, 1)'; // Orange
    const cC = 'rgba(34, 211, 238, 1)'; // Teal
    // Visual break points on slider (0-100 scale)
    const endA = 33.33; 
    const endB = 66.66;
    // Helper to map 0-100 slider to real inches
    const getRealValue = (p) => {
        if (p <= endA) return 6.0 + (p / endA) * (7.6 - 6.0);
        if (p <= endB) {
            const rel = (p - endA) / (endB - endA);
            return 7.6 + rel * (8.5 - 7.6);
        }
        const rel = (p - endB) / (100 - endB);
        return 8.5 + rel * (10.0 - 8.5);
    };
    const updateUI = () => {
        const p = parseFloat(slider.value);
        const real = getRealValue(p);
        // Color logic
        let color = cA;
        let zone = 'A';
        let rangeTxt = 'Hand span range: under 7.6 inches';
        let model = 'DS5.5';
        if(real >= 7.6) { color = cB; zone = 'B'; rangeTxt = '7.6 to 8.5 inches'; model = 'DS6.0'; }
        if(real > 8.5) { color = cC; zone = 'C'; rangeTxt = 'above 8.5 inches'; model = 'DS6.5'; }
        // Update CSS Var for thumb color
        slider.style.setProperty('--thumb-color', color);
        // Dynamic gradient on slider track
        const gradient = `linear-gradient(to right, ${color} 0%, ${color} ${p}%, rgba(255,255,255,0.1) ${p}%, rgba(255,255,255,0.1) 100%)`;
        slider.style.background = gradient;
        // Glow
        if(glow) glow.style.background = `linear-gradient(90deg, ${color}, transparent)`;
        // Text Updates
        valDisplay.innerHTML = `${real.toFixed(1)} in <span>/ ${(real * 2.54).toFixed(1)} cm</span>`;
        valDisplay.style.color = color;
        document.getElementById('dp-result-zone').innerText = `Zone ${zone}`;
        document.getElementById('dp-result-zone').style.color = color;
        document.getElementById('dp-result-range').innerText = rangeTxt;
        document.getElementById('dp-result-model').innerText = model;
        state.currentZone = zone;
    };
    slider.addEventListener('input', updateUI);
    updateUI(); // Init
}
function applySizingTool() {
    const zoneToSize = { 'A': 'small', 'B': 'medium', 'C': 'large' };
    const sizeId = zoneToSize[state.currentZone];
    handleHandSelect(sizeId);
    toggleModal(false);
}
</script>
