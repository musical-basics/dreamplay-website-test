                    <script>
    (function () {
      var slider = document.getElementById("dp-handspan-slider");
      var glowLayer = document.getElementById("dp-glow-layer");
      var valueEl = document.getElementById("dp-handspan-value");
      var zoneEl = document.getElementById("dp-result-zone");
      var rangeEl = document.getElementById("dp-result-range");
      var modelEl = document.getElementById("dp-result-model");
      var descEl = document.getElementById("dp-result-desc");
      var reachEl = document.getElementById("dp-result-reach");
      if (!slider || !valueEl) { return; }
      // --- 1. COLORS ---
      // ZONE A: HOT ROSE (Small / Urgent)
      var cZoneA = "rgba(244, 63, 94, 1)";    // Vivid
      var mZoneA = "rgba(244, 63, 94, 0.3)";  // Muted
      var gZoneA = "rgba(244, 63, 94, 0.5)";  // Glow
      // ZONE B: WARM AMBER (Average / Intermediate)
      // Replaced Purple with Amber for better logical flow
      var cZoneB = "rgba(245, 158, 11, 1)";   // Vivid
      var mZoneB = "rgba(245, 158, 11, 0.3)"; // Muted
      var gZoneB = "rgba(245, 158, 11, 0.5)"; // Glow
      // ZONE C: AQUAMARINE (Large / Standard)
      var cZoneC = "rgba(45, 212, 191, 1)";   // Vivid
      var mZoneC = "rgba(45, 212, 191, 0.3)"; // Muted
      var gZoneC = "rgba(45, 212, 191, 0.5)"; // Glow
      // --- 2. ZONE MATH (3 Even Visual Sections) ---
      var visualZoneA_End = 33.33; 
      var visualZoneB_End = 66.66; 
      // Helper: Map percent (0-100) to Real Inches
      function getRealValue(percent) {
        if (percent <= visualZoneA_End) {
          return 6.0 + (percent / visualZoneA_End) * (7.6 - 6.0);
        } else if (percent <= visualZoneB_End) {
          var relativeP = (percent - visualZoneA_End) / (visualZoneB_End - visualZoneA_End);
          return 7.6 + relativeP * (8.5 - 7.6);
        } else {
          var relativeP = (percent - visualZoneB_End) / (100 - visualZoneB_End);
          return 8.5 + relativeP * (10.0 - 8.5);
        }
      }
      // --- 3. SETUP STATIC BACKGROUNDS ---
      var mutedGradient = `linear-gradient(to right, 
          ${mZoneA} 0%, ${mZoneA} ${visualZoneA_End}%, 
          ${mZoneB} ${visualZoneA_End}%, ${mZoneB} ${visualZoneB_End}%, 
          ${mZoneC} ${visualZoneB_End}%, ${mZoneC} 100%)`;
      var glowGradient = `linear-gradient(to right, 
          ${gZoneA} 0%, ${gZoneA} ${visualZoneA_End}%, 
          ${gZoneB} ${visualZoneA_End}%, ${gZoneB} ${visualZoneB_End}%, 
          ${gZoneC} ${visualZoneB_End}%, ${gZoneC} 100%)`;
      if(glowLayer) { glowLayer.style.background = glowGradient; }
      // --- 4. VISUAL UPDATE FUNCTION ---
      function updateSliderVisuals(percent, activeColor) {
        var activeGradient = `linear-gradient(to right, 
             ${activeColor} 0%, 
             ${activeColor} ${percent}%, 
             rgba(0,0,0,0) ${percent}%, 
             rgba(0,0,0,0) 100%)`;
        slider.style.background = `${activeGradient}, ${mutedGradient}`;
        slider.style.setProperty('--thumb-color', activeColor);
      }
      // --- 5. MAIN LOGIC LOOP ---
      function updateFromSlider() {
        var percent = parseFloat(slider.value); // 0 to 100
        var realVal = getRealValue(percent);    // Real Inches
        var cm = realVal * 2.54;
        valueEl.innerHTML = realVal.toFixed(1) + " in " + '<span>/ ' + cm.toFixed(1) + " cm</span>";
        var zone = ""; var rangeText = ""; var model = ""; var desc = ""; var reach = ""; var activeColor = ""; 
        if (realVal < 7.6) {
          // ZONE A (Small - Red)
          zone = "A"; 
          rangeText = "Hand span range: under 7.6 inches"; 
          model = "DS5.5";
          desc = "Standard keys are physically too wide for you. The DS5.5 solves this by shrinking the octave, instantly removing tension.";
          reach = "Finally play 10ths comfortably"; 
          activeColor = cZoneA;
        } else if (realVal <= 8.5) {
          // ZONE B (Average - Amber)
          zone = "B"; 
          rangeText = "Hand span range: 7.6 to 8.5 inches"; 
          model = "DS6.0";
          desc = "The 'Goldilocks' size. Slightly narrower than standard, giving you the power of a concert pianist without the stretching fatigue.";
          reach = "Play 10ths with new ease";
          activeColor = cZoneB;
        } else {
          // ZONE C (Large - Teal)
          zone = "C"; 
          rangeText = "Hand span range: above 8.5 inches"; 
          model = "DS6.5";
          desc = "You fit the historical standard. Since your hands are naturally large, this model provides the traditional concert grand key width.";
          reach = "Master standard repertoire"; 
          activeColor = cZoneC;
        }
        zoneEl.textContent = "Zone " + zone;
        rangeEl.textContent = rangeText;
        modelEl.textContent = model;
        descEl.textContent = desc;
        reachEl.textContent = reach;
        // Update Text Colors
        valueEl.style.color = activeColor;
        zoneEl.style.color = activeColor;
        updateSliderVisuals(percent, activeColor);
      }
      updateFromSlider();
      slider.addEventListener("input", updateFromSlider);
    })();
</script>
