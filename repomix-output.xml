    useEffect(() => {
        if (pathname) {
            let url = pathname
            if (searchParams && searchParams.toString()) {
                url = url + `?${searchParams.toString()}`
            }

            // Log the page view
            logEvent('pageview', { path: url })
        }
    }, [pathname, searchParams])

    return null
}

export function AnalyticsTracker() {
    return (
        <Suspense fallback={null}>
            <AnalyticsTrackerContent />
        </Suspense>
    )
}
