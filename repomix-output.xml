    function initSizingToolSlider() {
      const slider = document.getElementById('dp-handspan-slider');
      const glowLayer = document.getElementById('dp-glow-layer');
      const valueEl = document.getElementById('dp-handspan-value');
      const zoneEl = document.getElementById('dp-result-zone');
      const rangeEl = document.getElementById('dp-result-range');
      const modelEl = document.getElementById('dp-result-model');
      const descEl = document.getElementById('dp-result-desc');
      const reachEl = document.getElementById('dp-result-reach');
      if (!slider || !valueEl) return;
      const cZoneA = 'rgba(239, 68, 68, 1)'; const mZoneA = 'rgba(239, 68, 68, 0.2)'; const gZoneA = 'rgba(239, 68, 68, 0.4)';
      const cZoneB = 'rgba(249, 115, 22, 1)'; const mZoneB = 'rgba(249, 115, 22, 0.2)'; const gZoneB = 'rgba(249, 115, 22, 0.4)';
      const cZoneC = 'rgba(34, 211, 238, 1)'; const mZoneC = 'rgba(34, 211, 238, 0.2)'; const gZoneC = 'rgba(34, 211, 238, 0.4)';
      const visualZoneA_End = 33.33; const visualZoneB_End = 66.66;
      function getRealValue(percent) {
        if (percent <= visualZoneA_End) return 6.0 + (percent / visualZoneA_End) * (7.6 - 6.0);
        else if (percent <= visualZoneB_End) { const relativeP = (percent - visualZoneA_End) / (visualZoneB_End - visualZoneA_End); return 7.6 + relativeP * (8.5 - 7.6); }
        else { const relativeP = (percent - visualZoneB_End) / (100 - visualZoneB_End); return 8.5 + relativeP * (10.0 - 8.5); }
      }
      const mutedGradient = `linear-gradient(to right, ${mZoneA} 0%, ${mZoneA} ${visualZoneA_End}%, ${mZoneB} ${visualZoneA_End}%, ${mZoneB} ${visualZoneB_End}%, ${mZoneC} ${visualZoneB_End}%, ${mZoneC} 100%)`;
      if (glowLayer) glowLayer.style.background = `linear-gradient(to right, ${gZoneA} 0%, ${gZoneA} ${visualZoneA_End}%, ${gZoneB} ${visualZoneA_End}%, ${gZoneB} ${visualZoneB_End}%, ${gZoneC} ${visualZoneB_End}%, ${gZoneC} 100%)`;
      function updateSliderVisuals(percent, activeColor) {
        slider.style.background = `linear-gradient(to right, ${activeColor} 0%, ${activeColor} ${percent}%, rgba(0,0,0,0) ${percent}%, rgba(0,0,0,0) 100%), ${mutedGradient}`;
        slider.style.setProperty('--thumb-color', activeColor);
      }
      function updateFromSlider() {
        const percent = parseFloat(slider.value);
        const realVal = getRealValue(percent);
        const cm = realVal * 2.54;
        if (valueEl) valueEl.innerHTML = realVal.toFixed(1) + ' in <span>/ ' + cm.toFixed(1) + ' cm</span>';
        let zone = '', rangeText = '', model = '', desc = '', reach = '', activeColor = '';
        if (realVal < 7.6) {
          zone = 'A'; rangeText = 'Hand span range: under 7.6 inches'; model = 'DS5.5'; desc = "Standard keys are physically too wide for you."; reach = 'Finally play 10ths comfortably'; activeColor = cZoneA; appState.currentZone = 'A';
        } else if (realVal <= 8.5) {
          zone = 'B'; rangeText = 'Hand span range: 7.6 to 8.5 inches'; model = 'DS6.0'; desc = "The 'Goldilocks' size. Slightly narrower than standard."; reach = 'Play 10ths with new ease'; activeColor = cZoneB; appState.currentZone = 'B';
        } else {
          zone = 'C'; rangeText = 'Hand span range: above 8.5 inches'; model = 'DS6.5'; desc = 'You fit the historical standard.'; reach = 'Master standard repertoire'; activeColor = cZoneC; appState.currentZone = 'C';
        }
        if (zoneEl) zoneEl.textContent = 'Zone ' + zone;
        if (rangeEl) rangeEl.textContent = rangeText;
        if (modelEl) modelEl.textContent = model;
        if (descEl) descEl.textContent = desc;
        if (reachEl) reachEl.textContent = reach;
        if (valueEl) valueEl.style.color = activeColor;
        if (zoneEl) zoneEl.style.color = activeColor;
        updateSliderVisuals(percent, activeColor);
      }
      updateFromSlider();
      slider.addEventListener('input', updateFromSlider);
    }
