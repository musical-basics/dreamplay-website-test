// --- Logic from use-mobile.ts ---
const MOBILE_BREAKPOINT = 768;
function initMobileDetection() {
    const checkMobile = () => {
        state.isMobile = window.innerWidth < MOBILE_BREAKPOINT;
        // Optional: Add logic here if you want to change layout dynamically via JS
        // based on mobile state (though CSS media queries are usually better).
    };
    // Initial check
    checkMobile();
    // Listener
    const mql = window.matchMedia(`(max-width: ${MOBILE_BREAKPOINT - 1}px)`);
    mql.addEventListener('change', checkMobile);
}
// --- Logic from use-toast.ts (Vanilla Implementation) ---
const ToastSystem = {
    limit: 1, // Matches TOAST_LIMIT in use-toast.ts
    toasts: [],
    show({ title, description, variant = 'default' }) {
        const viewport = document.getElementById('toast-viewport');
        // Respect limit: remove oldest if at limit
        if (this.toasts.length >= this.limit) {
            this.dismiss(this.toasts[0].id);
        }
        const id = 'toast-' + Math.random().toString(36).substr(2, 9);
        // Create DOM Element
        const el = document.createElement('div');
        el.id = id;
        el.className = `toast ${variant === 'destructive' ? 'toast-variant-destructive' : 'toast-variant-default'}`;
        // Inner HTML
        el.innerHTML = `
            <div class="grid gap-1">
                ${title ? `<div class="toast-title text-white">${title}</div>` : ''}
                ${description ? `<div class="toast-description">${description}</div>` : ''}
            </div>
            <button class="toast-close text-white" onclick="ToastSystem.dismiss('${id}')">
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.7816 4.03157C12.0062 3.80702 12.0062 3.44295 11.7816 3.2184C11.5571 2.99385 11.193 2.99385 10.9685 3.2184L7.50005 6.68682L4.03164 3.2184C3.80708 2.99385 3.44301 2.99385 3.21846 3.2184C2.99391 3.44295 2.99391 3.80702 3.21846 4.03157L6.68688 7.49999L3.21846 10.9684C2.99391 11.1929 2.99391 11.557 3.21846 11.7816C3.44301 12.0061 3.80708 12.0061 4.03164 11.7816L7.50005 8.31316L10.9685 11.7816C11.193 12.0061 11.5571 12.0061 11.7816 11.7816C12.0062 11.557 12.0062 11.1929 11.7816 10.9684L8.31322 7.49999L11.7816 4.03157Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            </button>
        `;
        viewport.appendChild(el);
        this.toasts.push({ id, el });
        // Auto dismiss logic (matches TOAST_REMOVE_DELAY, usually 5-10s)
        setTimeout(() => this.dismiss(id), 5000);
    },
    dismiss(id) {
        const index = this.toasts.findIndex(t => t.id === id);
        if (index === -1) return;
        const { el } = this.toasts[index];
        // Animation out
        el.classList.add('toast-exit');
