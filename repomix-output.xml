      <script>
    // App State
    const appState = {
      handSpan: null,
      size: null,
      color: null,
      selectedTier: 'full',
      fullName: '',
      email: '',
      address: '',
      city: '',
      state: '',
      zipCode: '',
      country: 'United States',
      currentZone: 'B'
    };
    // --- ASSET LOADER UTILITY ---
    function getAssetSrc(id) {
      const el = document.getElementById(id);
      return el ? el.src : ''; 
    }
    function getAssetHref(id) {
      const el = document.getElementById(id);
      return el ? el.href : ''; 
    }
    // --- ASSET LOADER LOGIC ---
    function initImages() {
      // 1. Load Images
      const imageMap = {
        'nav-logo-img': 'src-logo',
        'hero-main-img': 'src-hero',
        'target-finish-black': 'src-finish-black',
        'target-finish-white': 'src-finish-white',
        'target-hand-icon': 'src-hand-icon'
      };
      for (const [targetId, sourceId] of Object.entries(imageMap)) {
        const target = document.getElementById(targetId);
        const sourceSrc = getAssetSrc(sourceId);
        if (target && sourceSrc) {
          target.src = sourceSrc;
        }
      }
      // 2. Load Policy Link & Attach Modal
      const policyUrl = getAssetHref('link-policy');
      if (policyUrl && policyUrl !== '#' && policyUrl !== '') {
        // FIX: Added 'policy-link-refund' to this list
        const policyTargets = ['policy-link-size', 'policy-link-color', 'policy-link-refund'];
        policyTargets.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.href = '#'; 
                el.style.cursor = 'pointer';
                el.onclick = (e) => {
                    e.preventDefault();
                    openPolicyModal(policyUrl);
                };
            }
        });
      }
    }
    // --- SCROLL LOGIC ---
    function scrollToSection(index) {
      const section = document.getElementById(`section-${index}`);
      if (section) {
        section.scrollIntoView({ behavior: 'smooth' });
      }
    }
    let activeSection = 0;
    window.addEventListener('scroll', () => {
      const sections = document.querySelectorAll('.journey-section');
      const scrollPos = window.scrollY + window.innerHeight / 2;
      sections.forEach((section, index) => {
        const rect = section.getBoundingClientRect();
        const top = rect.top + window.scrollY;
        const bottom = top + rect.height;
        if (scrollPos >= top && scrollPos < bottom) {
          activeSection = index;
        }
      });
      const nav = document.getElementById('sticky-nav');
      if (nav) {
          if (window.scrollY > 100) {
            nav.classList.add('bg-[#0a0a0f]/95', 'py-3', 'shadow-lg', 'shadow-black/20', 'backdrop-blur-md');
            nav.classList.remove('bg-transparent', 'py-6');
          } else {
            nav.classList.remove('bg-[#0a0a0f]/95', 'py-3', 'shadow-lg', 'shadow-black/20', 'backdrop-blur-md');
            nav.classList.add('bg-transparent', 'py-6');
          }
      }
      updateStepNav();
      updateSelectionPreview();
    });
    function updateStepNav() {
      const steps = ['Start', 'Measure', 'Size', 'Color', 'Reserve'];
      const stepNav = document.getElementById('step-nav');
      if(!stepNav) return;
      stepNav.innerHTML = steps.map((label, index) => {
        const isActive = activeSection === index;
        const isCompleted = activeSection > index;
        const isClickable = index <= activeSection || isCompleted;
        return `
          <button
            onclick="${isClickable ? `scrollToSection(${index})` : ''}"
            ${!isClickable ? 'disabled' : ''}
            class="group relative flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium transition-all duration-300 ${
              isActive
                ? 'bg-[#4a9eff] text-white shadow-lg shadow-[#4a9eff]/30'
                : isCompleted
                  ? 'text-[#4a9eff] hover:bg-[#4a9eff]/10'
                  : 'text-white/40'
            } ${isClickable ? 'cursor-pointer' : 'cursor-not-allowed'}"
          >
            ${index > 0 ? `
              <span class="flex h-5 w-5 items-center justify-center rounded-full text-xs font-bold ${
                isActive
                  ? 'bg-white/20 text-white'
                  : isCompleted
                    ? 'bg-[#4a9eff]/20 text-[#4a9eff]'
                    : 'bg-white/10 text-white/40'
              }">
                ${isCompleted ? '✓' : index}
              </span>
            ` : ''}
            <span class="hidden lg:inline">${label}</span>
          </button>
        `;
      }).join('');
    }
    function updateSelectionPreview() {
      const preview = document.getElementById('selection-preview');
      if(!preview) return;
      if (appState.size || appState.color) {
        preview.classList.remove('hidden');
        preview.classList.add('flex');
        preview.innerHTML = `
          ${appState.size ? `<span class="text-[#4a9eff]">${appState.size}</span>` : ''}
          ${appState.size && appState.color ? '<span>•</span>' : ''}
          ${appState.color ? `<span class="text-[#4a9eff]">${appState.color}</span>` : ''}
        `;
      } else {
        preview.classList.add('hidden');
      }
    }
    // --- STEP 1: HAND SIZE SELECTION ---
    function selectHandSize(size, autoAdvance = true) {
      appState.handSpan = size;
      const sizeMap = { small: 'DS5.5', medium: 'DS6.0', large: 'DS6.5' };
      appState.size = sizeMap[size];
      document.querySelectorAll('.hand-size-btn').forEach(btn => {
        const btnSize = btn.getAttribute('data-hand-size');
        const emoji = btn.querySelector('span[role="img"]');
        // 1. Border Overlay Logic (Maintains the clean border)
        let borderOverlay = btn.querySelector('.border-overlay');
        if (!borderOverlay) {
            borderOverlay = document.createElement('div');
            borderOverlay.className = 'border-overlay absolute inset-0 rounded-xl md:rounded-2xl border-2 border-[#4a9eff] pointer-events-none z-50 transition-opacity duration-300 opacity-0';
            btn.appendChild(borderOverlay);
        }
        // 2. Target the "Select" Button inside the card
        const actionWrapper = btn.querySelector('.absolute.bottom-6'); 
        const actionBtn = actionWrapper ? actionWrapper.firstElementChild : null;
        if (btnSize === size) {
          // --- SELECTED STATE (Solid Blue) ---
          borderOverlay.classList.remove('opacity-0');
          borderOverlay.classList.add('opacity-100');
          btn.classList.remove('border-white/10', 'bg-white/5');
          btn.classList.add('border-transparent', 'bg-[#4a9eff]/5');
          if (emoji) {
            emoji.classList.remove('grayscale', 'opacity-70');
            emoji.classList.add('grayscale-0', 'opacity-100', 'drop-shadow-[0_0_12px_rgba(74,158,255,0.6)]');
          }
          if (!btn.querySelector('.selected-indicator')) {
            const checkmark = document.createElement('div');
            checkmark.className = 'selected-indicator absolute right-3 top-3 flex h-6 w-6 items-center justify-center rounded-full bg-[#4a9eff] z-50 shadow-lg';
            checkmark.innerHTML = '<svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
            btn.appendChild(checkmark);
          }
          // BUTTON STYLE: Solid Blue (100% Opacity)
          if (actionBtn) {
            actionBtn.textContent = 'Selected';
            actionBtn.classList.remove('bg-[#4a9eff]/50', 'border-[#4a9eff]/50'); // Remove 50% opacity style
            actionBtn.classList.add('bg-[#4a9eff]', 'border-[#4a9eff]', 'shadow-lg', 'shadow-[#4a9eff]/25'); // Add Solid style
          }
        } else {
          // --- UNSELECTED STATE (50% Opacity Blue) ---
          borderOverlay.classList.remove('opacity-100');
