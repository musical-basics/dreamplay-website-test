    <div class="w-embed w-script">
      <script>
// --- FOOTER NEWSLETTER HANDLER ---
    function handleFooterSubmit(e) {
      e.preventDefault();
      const submitBtn = document.getElementById('footer-submit-btn');
      const originalText = submitBtn.textContent;
      // 1. UI Feedback
      submitBtn.textContent = '...';
      submitBtn.disabled = true;
      // 2. CONFIGURATION (Same Link as your Main Form)
      const ACTION_URL = 'https://dreamplaypianos.us12.list-manage.com/subscribe/post?u=90fbaa21ba86eecae78c767a8&id=cc37fd2637&f_id=00c46be9f0';
      // 3. Payload (Only Name and Email)
      const payload = {
        'EMAIL': document.getElementById('footer-email').value,
        'FNAME': document.getElementById('footer-fname').value,
        // We do NOT send Address, Size, or Finish here.
      };
      // 4. Create Hidden Iframe
      const iframeName = 'footer_iframe_' + Date.now();
      const iframe = document.createElement('iframe');
      iframe.name = iframeName;
      iframe.style.display = 'none';
      document.body.appendChild(iframe);
      // 5. Create Form
      const form = document.createElement('form');
      form.action = ACTION_URL;
      form.method = 'POST';
      form.target = iframeName;
      // 6. Add Inputs
      for (const [key, value] of Object.entries(payload)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = value;
        form.appendChild(input);
      }
      // 7. Submit
      document.body.appendChild(form);
      form.submit();
      // 8. Success Message
      setTimeout(() => {
        alert('Thanks for subscribing!');
        submitBtn.textContent = '✓';
        // Clear inputs
        document.getElementById('footer-email').value = '';
        document.getElementById('footer-fname').value = '';
        // Cleanup
        setTimeout(() => {
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
            document.body.removeChild(form);
            document.body.removeChild(iframe);
        }, 2000);
      }, 1500);
    }
    </script>
