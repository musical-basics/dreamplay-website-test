        // --- CUSTOM FIELDS (UPDATED) ---
        // The LEFT side must match your Mailchimp "Merge tag" EXACTLY.
        'DP1SIZE': appState.size || 'Not Selected',   // Matches your new "DP1SIZE" tag
        'DP1FINISH': appState.color || 'Not Selected', // Make sure you name the finish tag "DP1FINISH" in Mailchimp!
        'DP1TIER': appState.selectedTier              // Make sure you name the tier tag "DP1TIER" in Mailchimp!
      };
      // -------------------------------------------------------
      // END CONFIGURATION
      // -------------------------------------------------------
      // 2. Create hidden iframe
      const iframeName = 'mc_iframe_' + Date.now();
      const iframe = document.createElement('iframe');
      iframe.name = iframeName;
      iframe.style.display = 'none';
      document.body.appendChild(iframe);
      // 3. Create Form
      const form = document.createElement('form');
      form.action = ACTION_URL;
      form.method = 'POST';
      form.target = iframeName;
      // 4. Add Inputs
      for (const [key, value] of Object.entries(payload)) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = value;
        form.appendChild(input);
      }
      // 5. Submit
      document.body.appendChild(form);
      form.submit();
      // 6. Success Message
      setTimeout(() => {
        alert('You have been added to the waitlist! Please check your email.');
        submitBtn.textContent = 'Success';
        // Cleanup
        document.body.removeChild(form);
        setTimeout(() => document.body.removeChild(iframe), 1000); 
      }, 1500);
    }
    // --- MODAL HELPERS (GLOBAL SCOPE) ---
    function openPolicyModal(url) {
      const modal = document.getElementById('policy-modal');
      const iframe = document.getElementById('policy-iframe');
      if (modal && iframe) {
        iframe.src = url; // Load the URL dynamically
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden'; // Stop background from scrolling
      }
    }
    function closePolicyModal() {
      const modal = document.getElementById('policy-modal');
      const iframe = document.getElementById('policy-iframe');
      if (modal && iframe) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        iframe.src = ''; // Clear it to save memory
        document.body.style.overflow = ''; // Let background scroll again
      }
    }
    document.addEventListener('DOMContentLoaded', () => {
      initImages(); 
      initPricingTiers();
      initCountdown();
      initCustomerCount();
      updateStepNav();
      updateOrderSummary();
      updateSubmitButton();
      initHeroAnimation();
    });
</script>
