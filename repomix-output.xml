      <script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Gather Valid Links
    const validLinks = [];
    // We loop through your 10 Webflow links (IDs dp-link-1 to dp-link-10)
    for (let i = 1; i <= 10; i++) {
      const sourceEl = document.getElementById(`dp-link-${i}`);
      if (sourceEl) {
        // Get the URL and clean it up
        const rawHref = sourceEl.getAttribute('href');
        const href = rawHref ? rawHref.trim() : "";
        const text = sourceEl.textContent.trim();
        // VALIDATION CHECK:
        // Exclude if href is missing, is just "#", is "http://#", or has no text.
        if (href && href !== '#' && href !== 'http://#' && href !== 'https://#' && text.length > 0) {
          validLinks.push({
            text: text,
            href: href,
            target: sourceEl.target || '_self' // Preserve "Open in new tab" setting
          });
        }
      }
    }
    // 2. Calculate Split
    // If we have 7 links, mid is 4. Left gets 0-4 (4 items), Right gets 4-end (3 items).
    const midPoint = Math.ceil(validLinks.length / 2);
    const leftLinks = validLinks.slice(0, midPoint);
    const rightLinks = validLinks.slice(midPoint);
    // 3. Render Function
    function renderLinks(links, containerId) {
      const container = document.getElementById(containerId);
      if (!container) return;
      // Clear existing content (just in case)
      container.innerHTML = '';
      links.forEach(linkData => {
        // Create <li>
        const li = document.createElement('li');
        // Create <a>
        const a = document.createElement('a');
        a.href = linkData.href;
        a.textContent = linkData.text;
        a.target = linkData.target;
        a.className = 'dp-nav-link'; // Apply your CSS class for hover effects
        // Assemble
        li.appendChild(a);
        container.appendChild(li);
      });
    }
    // 4. Execute Render
    renderLinks(leftLinks, 'dp-footer-list-left');
    renderLinks(rightLinks, 'dp-footer-list-right');
  });
</script>
