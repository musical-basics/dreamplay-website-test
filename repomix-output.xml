                    <script>
  (function () {
    // 1. Target the specific ID of the Science Block
    var section = document.getElementById("science-section");
    // Safety check
    if (!section) return;
    var donuts = section.querySelectorAll(".dp-donut");
    // Define the animation function
    function runAnimation() {
      donuts.forEach(function (donut) {
        var targetStr = donut.getAttribute("data-target-degree");
        if (!targetStr) return;
        var targetDegree = parseFloat(targetStr);
        var duration = 1500; // 1.5 seconds
        var startTime = null;
        // --- COLORS UPDATED HERE ---
        var colorRed = "#ff2d55";   // Matches your CSS Red
        var colorGreen = "#34c759"; // Matches your CSS Green
        // The frame-by-frame animation loop
        function animateFrame(timestamp) {
          if (!startTime) startTime = timestamp;
          var progress = timestamp - startTime;
          // Calculate how far along we are (0 to 1)
          var percent = Math.min(progress / duration, 1);
          // Ease Out Quart (Smooth slow down)
          var ease = 1 - Math.pow(1 - percent, 4);
          var currentAngle = targetDegree * ease;
          // Apply the gradient dynamically
          // This draws RED from 0 to currentAngle, and GREEN for the rest
          donut.style.background = `conic-gradient(${colorRed} 0deg ${currentAngle}deg, ${colorGreen} ${currentAngle}deg 360deg)`;
          // Keep running until time is up
          if (progress < duration) {
            window.requestAnimationFrame(animateFrame);
          }
        }
        // Kick off the loop
        window.requestAnimationFrame(animateFrame);
      });
    }
    // 2. Set up the Observer to trigger on scroll
    if ("IntersectionObserver" in window) {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              runAnimation();
              observer.disconnect(); // Run once and stop
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(section);
    } else {
      // Fallback for older browsers
      runAnimation();
    }
  })();
</script>
