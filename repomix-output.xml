    useEffect(() => {
        loadData()
    }, [activeTab, timeRange])

    const loadData = async () => {
        setLoading(true)
        try {
            if (activeTab === 'logs') {
                const recentLogs = await getRecentLogs()
                setLogs(recentLogs)
            } else if (activeTab === 'ab-test') {
                const testStats = await getABTestStats()
