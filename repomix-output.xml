        <script>
    (function() {
      /* ----------------------------------------------------
         PART 1: IMAGE SWAP LOGIC (WEBFLOW INTEGRATION)
      ------------------------------------------------------ */
      function swapImageSource(sourceId, targetId) {
        var sourceEl = document.getElementById(sourceId);
        var targetEl = document.getElementById(targetId);
        if (sourceEl && targetEl) {
          if(sourceEl.getAttribute('src')) {
             targetEl.setAttribute('src', sourceEl.getAttribute('src'));
             if(sourceEl.getAttribute('srcset')) {
               targetEl.setAttribute('srcset', sourceEl.getAttribute('srcset'));
             }
          }
        }
      }
      // 1. Swap Main Slides (Wide shots)
      swapImageSource('source-img-1', 'target-slide-1');
      swapImageSource('source-img-2', 'target-slide-2');
      swapImageSource('source-img-3', 'target-slide-3');
      // 2. Swap Avatars (Profile pics)
      swapImageSource('source-avatar-1', 'target-avatar-1');
      swapImageSource('source-avatar-2', 'target-avatar-2');
      swapImageSource('source-avatar-3', 'target-avatar-3');
      /* ----------------------------------------------------
         PART 2: SLIDER LOGIC
      ------------------------------------------------------ */
      const track = document.getElementById('dpTrack');
      const prevBtn = document.getElementById('dpPrev');
      const nextBtn = document.getElementById('dpNext');
      const dots = document.getElementById('dpDots').children;
      let currentIndex = 0;
      const totalSlides = 3;
      function updateSlider() {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        Array.from(dots).forEach((dot, index) => {
          if(index === currentIndex) dot.classList.add('active');
          else dot.classList.remove('active');
        });
      }
      window.goToSlide = function(index) {
        currentIndex = index;
        updateSlider();
      }
      function nextSlide() {
        currentIndex = (currentIndex + 1) % totalSlides;
        updateSlider();
      }
      function prevSlide() {
        currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
        updateSlider();
      }
      if(nextBtn) nextBtn.addEventListener('click', nextSlide);
      if(prevBtn) prevBtn.addEventListener('click', prevSlide);
    })();
  </script>
