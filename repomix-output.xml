    <script>
  document.addEventListener("DOMContentLoaded", function() {
    // --- 1. ASSET LOADER ---
    const mappings = [
      { source: 'loader-hero-bg', target: 'target-hero-bg' },
      { source: 'loader-edu-1', target: 'target-edu-1' },
      { source: 'loader-edu-2', target: 'target-edu-2' },
      { source: 'loader-edu-3', target: 'target-edu-3' },
      { source: 'loader-edu-4', target: 'target-edu-4' },
      { source: 'loader-bundle-main', target: 'target-bundle-main' },
      { source: 'loader-bundle-stand', target: 'target-bundle-stand' },
      { source: 'loader-bundle-bench', target: 'target-bundle-bench' },
      { source: 'loader-link-shop', target: 'target-link-hero-shop', type: 'link' },
      { source: 'loader-link-learn', target: 'target-link-hero-learn', type: 'link' },
      { source: 'loader-link-app', target: 'target-link-app', type: 'link' },
      { source: 'loader-link-compare', target: 'target-link-compare', type: 'link' },
      { source: 'loader-link-bundle', target: 'target-link-bundle', type: 'link' },
      { source: 'loader-link-footer', target: 'target-link-footer', type: 'link' },
      { source: 'loader-video-bg', target: 'target-video-bg', type: 'video' }
    ];
    mappings.forEach(map => {
      const source = document.getElementById(map.source);
      const target = document.getElementById(map.target);
      if (source && target) {
        if (map.type === 'link') {
          target.href = source.href;
        } else if (map.type === 'video') {
          const videoElement = source.querySelector('video') || source.querySelector('source');
          if (videoElement) {
             const videoUrl = videoElement.currentSrc || videoElement.src;
             if(videoUrl) { target.src = videoUrl; target.load(); }
          }
        } else {
          target.src = source.src;
          if(source.srcset) target.srcset = source.srcset;
        }
      }
    });
    // --- 2. SCROLL ANIMATIONS ---
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    // --- 3. PARALLAX ---
    const parallaxBg = document.getElementById('hero-parallax');
    if (parallaxBg) {
      window.addEventListener('scroll', () => {
        parallaxBg.style.transform = `translateY(${window.scrollY * 0.2}px)`;
      });
    }
  });
  // --- 4. VIDEO MODAL FUNCTIONS ---
  function openVideoModal() {
    const modal = document.getElementById('video-modal');
    const targetVideo = document.getElementById('target-video-modal');
    const sourceContainer = document.getElementById('loader-video-modal');
    let videoUrl = "";
    if (sourceContainer) {
        const videoEl = sourceContainer.querySelector('video');
        const sourceEl = sourceContainer.querySelector('source');
        if (videoEl && (videoEl.currentSrc || videoEl.src)) {
            videoUrl = videoEl.currentSrc || videoEl.src;
        } else if (sourceEl && sourceEl.src) {
            videoUrl = sourceEl.src;
        }
    }
    if (videoUrl && targetVideo.src !== videoUrl) {
        targetVideo.src = videoUrl;
        targetVideo.load();
    }
    modal.classList.add('open');
    targetVideo.play().catch(e => console.log("Autoplay blocked:", e));
  }
  function closeModal() {
    const modal = document.getElementById('video-modal');
    const video = document.getElementById('target-video-modal');
    modal.classList.remove('open');
    if (video) video.pause();
  }
</script>
