      <script>
  document.addEventListener("DOMContentLoaded", function() {
    // 1. ASSET MAPPINGS
    const mappings = [
      { source: 'loader-map', target: 'target-map' },
      { source: 'loader-box', target: 'target-box' },
      { source: 'loader-prod-1', target: 'target-prod-1' },
      { source: 'loader-prod-2', target: 'target-prod-2' },
      { source: 'loader-prod-3', target: 'target-prod-3' },
      { source: 'loader-link', target: 'target-cta-link', type: 'link' }
    ];
    mappings.forEach(map => {
      const sourceEl = document.getElementById(map.source);
      const targetEl = document.getElementById(map.target);
      if (sourceEl && targetEl) {
        if (map.type === 'link') {
          targetEl.href = sourceEl.href;
        } else {
          targetEl.src = sourceEl.src;
          if(sourceEl.srcset) targetEl.srcset = sourceEl.srcset;
        }
      }
    });
    // 2. SCROLL ANIMATIONS (Reveal)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    // 3. SCROLL LOCK FIX (The fix for "it scrolls the main page")
    // This forces the wheel event to be consumed by the list if mouse is over it
    document.querySelectorAll('.custom-scroll').forEach(el => {
      el.addEventListener('wheel', function(e) {
        // Calculate bounds
        const scrollTop = this.scrollTop;
        const scrollHeight = this.scrollHeight;
        const height = this.clientHeight;
        const delta = e.deltaY;
        const isScrollUp = delta < 0;
        const isScrollDown = delta > 0;
        // If content is smaller than container, do nothing (let page scroll)
        if (scrollHeight <= height) return;
        // If we are scrolling inside the bounds, STOP page scroll and manually scroll element
        if ((isScrollUp && scrollTop > 0) || (isScrollDown && scrollTop < scrollHeight - height)) {
             e.preventDefault();
             this.scrollTop += delta;
        }
        // If we hit the bottom/top, we let the default browser behavior happen (often nothing due to overscroll-contain)
      }, { passive: false });
    });
  });
</script>
