{
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "_static_source/**",
            "public/**",
            "pnpm-lock.yaml",
            "package-lock.json",
            "yarn.lock",
            "**/*.svg",
            "**/*.png",
            "**/*.jpg",
            "**/*.jpeg",
            "**/*.gif",
            "**/*.ico",
            "**/*.webp",
            "**/*.avif",
            "**/*.mp4",
            "**/*.mov",
            "**/*.pdf",
            "dist/**",
            ".next/**",
            "migrations/**"
        ]
    }
}